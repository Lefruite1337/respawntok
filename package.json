{
  "name": "respawntok",
  "version": "1.0.0",
  "description": "Auto-show TikTok feed when you die in CS2/Dota2 via Game State Integration",
  "main": "main.js",
  "scripts": {
    "start": "electron .",
    "install-gsi": "node gsi-installer.js",
    "build-icon": "node scripts/build-icon.js",
    "build": "node scripts/build-icon.js && electron-builder --win",
    "deploy": "wrangler deploy",
    "preview": "wrangler dev"
  },
  "dependencies": {
    "electron-updater": "^6.8.3",
    "express": "^4.18.2"
  },
  "devDependencies": {
    "electron": "^41.0.0",
    "electron-builder": "^26.8.1",
    "png-to-ico": "^3.0.1",
    "sharp": "^0.34.5",
    "wrangler": "^4.72.0"
  },
  "build": {
    "appId": "com.respawntok.app",
    "productName": "RespawnTok",
    "win": {
      "target": "nsis",
      "icon": "assets/icon.ico"
    },
    "nsis": {
      "oneClick": true,
      "perMachine": false
    },
    "files": [
      "**/*",
      "!site/**",
      "!**/*.md"
    ],
    "publish": {
      "provider": "generic",
      "url": "https://your-site.com/releases/"
    }
  }
}
